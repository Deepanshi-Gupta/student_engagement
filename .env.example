# Copy this file to ".env" and fill in your key. The .env file is read
# automatically at startup (observations.py). NEVER commit your real .env.

# NVIDIA API key for the Observations layer (https://build.nvidia.com).
# If unset, observations.py falls back to the key baked into the file so it
# still runs — but set yours here and rotate the shared one for real use.
NVIDIA_API_KEY=nvapi-your_key_here

# Optional — pick any model on the NVIDIA endpoint. Default is a fast one
# (~2-3s). The big nvidia/nemotron-3-ultra-550b-a55b model works too but
# takes ~110s per call, which is too slow for a live panel.
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Optional — runtime context / mode (run.py flags override these).
# MONITOR_MODE=live
# MONITOR_TOPIC=the current lesson
